# Datenbank
# Lokal:      DATABASE_URL="file:./prisma/dev.db"
# Produktion: DATABASE_URL="libsql://immomanage-xyz.turso.io"
DATABASE_URL="file:./prisma/dev.db"
# DATABASE_AUTH_TOKEN=""   # nur für Turso/remote libsql

# NextAuth — NEXTAUTH_SECRET mit: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# SMTP (lokal: Mailpit auf Port 1025, Produktion: echter SMTP-Anbieter)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_FROM='"ImmoManage" <noreply@immomanage.local>'
# SMTP_USER="user@example.com"   # nur wenn Auth nötig
# SMTP_PASS="password"

# KI-Agent (Ollama lokal, oder externer Endpunkt)
OLLAMA_BASE_URL="http://localhost:11434"
