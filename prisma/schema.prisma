// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  VERMIETER
  MIETER
  EIGENTUEMER
}

enum PropertyType {
  SINGLE
  MULTI
}

enum LeaseStatus {
  ACTIVE
  ENDED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum DocumentCategory {
  MIETVERTRAG
  HAUSORDNUNG
  NEBENKOSTENABRECHNUNG
  UEBERGABEPROTOKOLL
  SONSTIGES
  EINLADUNG
  VERSAMMLUNGSPROTOKOLL
  VOLLMACHT
  JAHRESRECHNUNG
  BUDGET
  HAUSWART_BELEG
}

enum DocumentScope {
  TENANT
  PROPERTY
  GLOBAL
}

enum DocumentFolderType {
  PERSONAL
  GENERAL
  ASSEMBLY
}

enum MessageSource {
  MANUAL
  AI_ESCALATION
}

enum AgentRole {
  USER
  AGENT
}

enum MeterType {
  STROM
  GAS
  WASSER
  HEIZUNG
}

enum HandoverType {
  EINZUG
  AUSZUG
}

enum HandoverStatus {
  ENTWURF
  ABGESCHLOSSEN
}

enum CalendarEventType {
  VERTRAGSENDE
  ABLESUNG
  KUENDIGUNG
  WARTUNG
  SONSTIGES
}

enum UnitStatus {
  VERMIETET
  LEER
  RENOVIERUNG
}

enum DepositStatus {
  AUSSTEHEND
  HINTERLEGT
  FREIGEGEBEN
}

enum RentDemandStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  QR_RECHNUNG
}

enum TaskType {
  WARTUNG
  REPARATUR
  VERTRAGSVERLAENGERUNG
  BESICHTIGUNG
  SONSTIGES
}

enum TaskStatus {
  OFFEN
  IN_BEARBEITUNG
  ERLEDIGT
}

enum AccountDeletionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Plan {
  STARTER
  STANDARD
  PRO
  ENTERPRISE
}

enum PlanStatus {
  TRIAL
  PENDING_PAYMENT
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum TicketScope {
  UNIT
  BUILDING
}

enum StegBudgetStatus {
  ENTWURF
  VERABSCHIEDET
  ABGESCHLOSSEN
}

enum JahresabrechnungStatus {
  ENTWURF
  VERSANDT
  GENEHMIGT
}

model Company {
  id                   String          @id @default(cuid())
  name                 String
  slug                 String          @unique
  logoUrl              String?
  active               Boolean         @default(true)
  plan                 Plan            @default(STARTER)
  planStatus           PlanStatus      @default(ACTIVE)
  trialEndsAt          DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  onboardingCompleted  Boolean         @default(false)
  smtpConfig           Json?
  createdAt            DateTime        @default(now())
  users                  User[]
  properties             Property[]
  tickets                Ticket[]
  documents              Document[]
  messages               Message[]
  leases                 Lease[]
  agentChats             AgentChat[]
  utilityBills           UtilityBill[]
  calendarEvents         CalendarEvent[]
  meterReadings          MeterReading[]
  handovers              Handover[]
  rentDemands            RentDemand[]
  tasks                  Task[]
  activityLogs           ActivityLog[]
  accountDeletionRequests AccountDeletionRequest[]
  folders                DocumentFolder[]         @relation("CompanyFolders")
  hauswartEntries        HauswartEntry[]          @relation("CompanyHauswartEntries")
  budgets                StegBudget[]             @relation("CompanyBudgets")
  jahresabrechnungen     StegJahresabrechnung[]   @relation("CompanyJahresabrechnungen")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role
  name         String
  phone        String?
  whatsapp     String?
  iban         String?
  active          Boolean  @default(true)
  emailVerified   Boolean  @default(true)
  companyId    String?
  createdAt    DateTime @default(now())
  company             Company?             @relation(fields: [companyId], references: [id])
  propertyAssignments PropertyAssignment[]
  propertyOwnerships  PropertyOwner[]
  leases              Lease[]              @relation("TenantLeases")
  tickets             Ticket[]             @relation("TenantTickets")
  ticketComments      TicketComment[]
  uploadedDocuments   Document[]           @relation("UploadedDocuments")
  tenantDocuments     Document[]           @relation("TenantDocuments")
  sentMessages        Message[]            @relation("SentMessages")
  receivedMessages    Message[]            @relation("ReceivedMessages")
  notifications       Notification[]
  calendarEvents      CalendarEvent[]
  agentChats          AgentChat[]          @relation("AgentChatTenant")
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  meterReadings            MeterReading[]       @relation("TenantMeterReadings")
  activityLogs        ActivityLog[]
  deletionRequest     AccountDeletionRequest?
  personalFolders     DocumentFolder[]     @relation("PersonalFolders")
  hauswartEntries     HauswartEntry[]      @relation("HauswartEntryCreator")
}

model PropertyAssignment {
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  @@id([userId, propertyId])
}

model PropertyOwner {
  id               String    @id @default(cuid())
  userId           String
  propertyId       String
  unitId           String?
  ownerSince       DateTime?
  createdAt        DateTime  @default(now())
  wertquote        Float     @default(0)
  hypothekarbetrag Float?
  hypothekarzins   Float?
  bankverbindung   String?
  zahlungsIban     String?
  mea              Int       @default(0)
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  property           Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit               Unit?                @relation(fields: [unitId], references: [id])
  taxEntries         WegTaxEntry[]
  expensePayments    OwnerExpensePayment[]
  assemblyVotes      AssemblyVote[]
  assemblyAttendance AssemblyAttendance[]
  statements         StegOwnerStatement[] @relation("OwnerStatements")
  vertreterFuer      AssemblyAttendance[] @relation("VertretenDurch")
}

model Property {
  id          String       @id @default(cuid())
  companyId   String
  name        String
  address     String
  type        PropertyType
  unitCount   Int
  year        Int?
  description String?
  isWeg       Boolean      @default(false)
  createdAt   DateTime     @default(now())
  company        Company              @relation(fields: [companyId], references: [id])
  units          Unit[]
  tickets        Ticket[]
  documents      Document[]
  assignments    PropertyAssignment[]
  owners         PropertyOwner[]
  utilityBills   UtilityBill[]
  calendarEvents CalendarEvent[]
  tasks          Task[]
  wegConfig      WegConfig?
  folders        DocumentFolder[]     @relation("PropertyFolders")
  hauswartEntries HauswartEntry[]     @relation("PropertyHauswartEntries")
  budgets        StegBudget[]         @relation("PropertyBudgets")
  jahresabrechnungen StegJahresabrechnung[] @relation("PropertyJahresabrechnungen")
}

model Unit {
  id         String     @id @default(cuid())
  propertyId String
  unitNumber String
  floor      Int?
  size       Float?
  rooms      Float?
  status     UnitStatus @default(LEER)
  photos     Json?
  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases         Lease[]
  tickets        Ticket[]
  owners         PropertyOwner[]
  calendarEvents CalendarEvent[]
}

model Lease {
  id                String        @id @default(cuid())
  unitId            String
  tenantId          String
  companyId         String
  status            LeaseStatus   @default(ACTIVE)
  startDate         DateTime
  endDate           DateTime?
  coldRent          Float
  extraCosts        Float
  depositPaid       Boolean       @default(false)
  depositAmount     Float?
  depositBank       String?
  depositStatus     DepositStatus @default(AUSSTEHEND)
  indexierung       Boolean       @default(false)
  referenzzinssatz  Float?
  contractPdf       String?
  handoverWizard    Json?
  createdAt         DateTime      @default(now())
  unit          Unit          @relation(fields: [unitId], references: [id])
  tenant        User          @relation("TenantLeases", fields: [tenantId], references: [id])
  company       Company       @relation(fields: [companyId], references: [id])
  utilityBills  UtilityBill[]
  meterReadings MeterReading[]
  handovers     Handover[]
  rentDemands   RentDemand[]
}

model Ticket {
  id          String       @id @default(cuid())
  companyId   String
  propertyId  String
  tenantId    String
  unitId      String?
  title       String
  description String
  status      TicketStatus @default(OPEN)
  priority    Priority     @default(MEDIUM)
  scope       TicketScope  @default(UNIT)
  images      Json
  repairCost  Float?
  createdAt   DateTime     @default(now())
  company  Company         @relation(fields: [companyId], references: [id])
  property Property        @relation(fields: [propertyId], references: [id])
  tenant   User            @relation("TenantTickets", fields: [tenantId], references: [id])
  unit     Unit?           @relation(fields: [unitId], references: [id])
  comments TicketComment[]
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  text      String
  createdAt DateTime @default(now())
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])
}

model Document {
  id            String           @id @default(cuid())
  companyId     String
  name          String
  category      DocumentCategory
  fileUrl       String
  fileType      String
  scope         DocumentScope
  tenantId      String?
  propertyId    String?
  uploadedById  String
  extractedText String?
  indexed       Boolean          @default(false)
  createdAt     DateTime         @default(now())
  folderId      String?
  company    Company         @relation(fields: [companyId], references: [id])
  tenant     User?           @relation("TenantDocuments", fields: [tenantId], references: [id])
  property   Property?       @relation(fields: [propertyId], references: [id])
  uploadedBy User            @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  folder     DocumentFolder? @relation(fields: [folderId], references: [id])
  hauswartBeleg HauswartEntry[]      @relation("HauswartBeleg")
  vollmachtFuer AssemblyAttendance[] @relation("VollmachtDok")
}

model Message {
  id        String        @id @default(cuid())
  companyId String
  fromId    String
  toId      String
  text      String
  read      Boolean       @default(false)
  source    MessageSource @default(MANUAL)
  createdAt DateTime      @default(now())
  company Company @relation(fields: [companyId], references: [id])
  from    User    @relation("SentMessages", fields: [fromId], references: [id])
  to      User    @relation("ReceivedMessages", fields: [toId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  text      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
}

model UtilityBill {
  id              String    @id @default(cuid())
  leaseId         String
  companyId       String
  propertyId      String
  year            Int
  amount          Float
  costItems       Json?
  distributionKey String    @default("sqm")
  tenantShares    Json?
  pdfUrl          String?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  lease    Lease    @relation(fields: [leaseId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
}

model CalendarEvent {
  id            String            @id @default(cuid())
  companyId     String
  userId        String
  title         String
  date          DateTime
  type          CalendarEventType
  autoGenerated Boolean           @default(false)
  relatedId     String?
  propertyId    String?
  unitId        String?
  createdAt     DateTime          @default(now())
  company  Company   @relation(fields: [companyId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])
  unit     Unit?     @relation(fields: [unitId], references: [id])
}

model AgentChat {
  id        String   @id @default(cuid())
  companyId String
  tenantId  String
  createdAt DateTime @default(now())
  company  Company        @relation(fields: [companyId], references: [id])
  tenant   User           @relation("AgentChatTenant", fields: [tenantId], references: [id])
  messages AgentMessage[]
}

model AgentMessage {
  id           String    @id @default(cuid())
  chatId       String
  role         AgentRole
  content      String
  sources      Json
  wasEscalated Boolean   @default(false)
  createdAt    DateTime  @default(now())
  chat AgentChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MeterReading {
  id          String    @id @default(cuid())
  companyId   String
  leaseId     String
  tenantId    String
  type        MeterType
  value       Float
  unit        String    @default("kWh")
  readingDate DateTime
  imageUrl    String?
  note        String?
  createdAt   DateTime  @default(now())
  company Company @relation(fields: [companyId], references: [id])
  lease   Lease   @relation(fields: [leaseId], references: [id])
  tenant  User    @relation("TenantMeterReadings", fields: [tenantId], references: [id])
}

model Handover {
  id         String         @id @default(cuid())
  companyId  String
  leaseId    String
  type       HandoverType
  date       DateTime
  status     HandoverStatus @default(ENTWURF)
  notes      String?
  rooms      Json           // RoomEntry[] als JSON
  signedByTenant   Boolean  @default(false)
  signedByVermieter Boolean @default(false)
  createdAt  DateTime       @default(now())
  company Company @relation(fields: [companyId], references: [id])
  lease   Lease   @relation(fields: [leaseId], references: [id])
}

model RentDemand {
  id          String           @id @default(cuid())
  companyId   String
  leaseId     String
  month       Int              // 1–12
  year        Int
  amount      Float
  dueDate     DateTime
  status      RentDemandStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  company   Company         @relation(fields: [companyId], references: [id])
  lease     Lease           @relation(fields: [leaseId], references: [id])
  payments  Payment[]
  reminders PaymentReminder[]
}

model Payment {
  id            String        @id @default(cuid())
  rentDemandId  String
  amount        Float
  paymentDate   DateTime
  method        PaymentMethod @default(BANK_TRANSFER)
  note          String?
  createdAt     DateTime      @default(now())
  rentDemand RentDemand @relation(fields: [rentDemandId], references: [id])
}

model PaymentReminder {
  id           String   @id @default(cuid())
  rentDemandId String
  level        Int      // 1, 2, 3
  sentAt       DateTime @default(now())
  rentDemand RentDemand @relation(fields: [rentDemandId], references: [id])
}

model Task {
  id          String     @id @default(cuid())
  companyId   String
  title       String
  description String?
  type        TaskType   @default(SONSTIGES)
  status      TaskStatus @default(OFFEN)
  dueDate     DateTime?
  reminderDays Int?
  propertyId  String?
  leaseId     String?
  createdAt   DateTime   @default(now())
  company  Company   @relation(fields: [companyId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model AccountDeletionRequest {
  id         String                @id @default(cuid())
  userId     String                @unique
  companyId  String
  status     AccountDeletionStatus @default(PENDING)
  reason     String?
  createdAt  DateTime              @default(now())
  resolvedAt DateTime?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])
}

// ─── WEG Enums ────────────────────────────────────────────────────────────────

enum HauswartKategorie {
  STUNDEN
  SPESEN
  MATERIAL
  FREMDLEISTUNG
}

enum ExpenseCategory {
  VERSICHERUNG
  HAUSWART
  REINIGUNG
  ALLGEMEINSTROM
  LIFT_SERVICE
  GARTEN
  SCHNEERAEUMUNG
  VERWALTUNGSHONORAR
  HEIZUNG
  SONSTIGES
}

enum ExpenseStatus {
  OFFEN
  BEZAHLT
  UEBERFAELLIG
}

enum PaymentRhythm {
  MONATLICH
  QUARTAL
  JAEHRLICH
}

// ─── WEG Models ───────────────────────────────────────────────────────────────

model WegConfig {
  id                    String    @id @default(cuid())
  propertyId            String    @unique
  kanton                String?
  gebVersicherungswert  Float?
  verkehrswert          Float?
  fondsBeitragssatz     Float     @default(0.4)
  fondsObergrenze       Float     @default(5.0)
  fondsStand            Float?
  fondsLetzteEinzahlung DateTime?
  hauswartStundenansatz Float     @default(45.0)
  createdAt             DateTime  @default(now())
  property     Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  renewalItems RenewalPlanItem[]
  expenses     CommunityExpense[]
  assemblies   Assembly[]
}

model RenewalPlanItem {
  id                String   @id @default(cuid())
  wegConfigId       String
  bauteil           String
  restlebensdauer   Int?
  erneuerungskosten Float?
  letzteErneuerung  Int?
  createdAt         DateTime @default(now())
  wegConfig WegConfig @relation(fields: [wegConfigId], references: [id], onDelete: Cascade)
}

model CommunityExpense {
  id                String          @id @default(cuid())
  wegConfigId       String
  kategorie         ExpenseCategory @default(SONSTIGES)
  beschreibung      String?
  betrag            Float
  rhythmus          PaymentRhythm   @default(JAEHRLICH)
  status            ExpenseStatus   @default(OFFEN)
  lieferant         String?
  faelligkeitsdatum DateTime?
  createdAt         DateTime        @default(now())
  wegConfig WegConfig             @relation(fields: [wegConfigId], references: [id], onDelete: Cascade)
  payments  OwnerExpensePayment[]
}

model OwnerExpensePayment {
  id         String        @id @default(cuid())
  expenseId  String
  ownerId    String
  betrag     Float
  bezahltAm  DateTime?
  status     ExpenseStatus @default(OFFEN)
  createdAt  DateTime      @default(now())
  expense CommunityExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  owner   PropertyOwner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model WegTaxEntry {
  id             String   @id @default(cuid())
  ownerId        String
  steuerjahr     Int
  kanton         String?
  eigenmietwert  Float?
  abzugsmethode  String   @default("PAUSCHAL")
  createdAt      DateTime @default(now())
  owner      PropertyOwner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  deductions WegTaxDeduction[]
}

model WegTaxDeduction {
  id           String    @id @default(cuid())
  taxEntryId   String
  datum        DateTime?
  beschreibung String
  betrag       Float
  kategorie    String
  taxEntry WegTaxEntry @relation(fields: [taxEntryId], references: [id], onDelete: Cascade)
}

model Assembly {
  id                   String    @id @default(cuid())
  wegConfigId          String
  datum                DateTime
  ort                  String?
  einladungsFrist      Int       @default(10)
  status               String    @default("GEPLANT")
  protokoll            String?
  einladungVersandtAt  DateTime?
  vollmachtFrist       DateTime?
  createdAt            DateTime  @default(now())
  wegConfig  WegConfig            @relation(fields: [wegConfigId], references: [id], onDelete: Cascade)
  agenda     AgendaItem[]
  attendance AssemblyAttendance[]
  folders    DocumentFolder[]     @relation("AssemblyFolders")
}

model AgendaItem {
  id            String   @id @default(cuid())
  assemblyId    String
  position      Int
  titel         String
  beschreibung  String?
  antragsteller String?
  budgetId      String?
  createdAt     DateTime @default(now())
  assembly Assembly      @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  votes    AssemblyVote[]
  budget   StegBudget?   @relation(fields: [budgetId], references: [id])
}

model AssemblyVote {
  id           String @id @default(cuid())
  agendaItemId String
  ownerId      String
  stimme       String
  meaGewicht   Int    @default(0)
  agendaItem AgendaItem    @relation(fields: [agendaItemId], references: [id], onDelete: Cascade)
  owner      PropertyOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  @@unique([agendaItemId, ownerId])
}

model AssemblyAttendance {
  id              String  @id @default(cuid())
  assemblyId      String
  ownerId         String
  anwesend        Boolean @default(false)
  vertretenDurch  String?
  vollmachtDokId  String?
  assembly    Assembly       @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  owner       PropertyOwner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  vertreter   PropertyOwner? @relation("VertretenDurch", fields: [vertretenDurch], references: [id])
  vollmachtDok Document?     @relation("VollmachtDok", fields: [vollmachtDokId], references: [id])
  @@unique([assemblyId, ownerId])
}

model DocumentFolder {
  id          String             @id @default(cuid())
  companyId   String
  propertyId  String?
  ownerId     String?
  assemblyId  String?
  type        DocumentFolderType
  name        String
  isSystem    Boolean            @default(false)
  parentId    String?
  createdAt   DateTime           @default(now())

  company   Company          @relation("CompanyFolders", fields: [companyId], references: [id], onDelete: Cascade)
  property  Property?        @relation("PropertyFolders", fields: [propertyId], references: [id], onDelete: Cascade)
  owner     User?            @relation("PersonalFolders", fields: [ownerId], references: [id], onDelete: Cascade)
  assembly  Assembly?        @relation("AssemblyFolders", fields: [assemblyId], references: [id], onDelete: Cascade)
  parent    DocumentFolder?  @relation("SubFolders", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("SubFolders")
  documents Document[]
}

model HauswartEntry {
  id            String            @id @default(cuid())
  companyId     String
  propertyId    String
  datum         DateTime
  kategorie     HauswartKategorie
  beschreibung  String
  stunden       Float?
  betrag        Float?
  belegId       String?
  createdById   String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  company   Company   @relation("CompanyHauswartEntries", fields: [companyId], references: [id], onDelete: Cascade)
  property  Property  @relation("PropertyHauswartEntries", fields: [propertyId], references: [id], onDelete: Cascade)
  beleg     Document? @relation("HauswartBeleg", fields: [belegId], references: [id])
  createdBy User      @relation("HauswartEntryCreator", fields: [createdById], references: [id])
}

// ─── STEG Models ──────────────────────────────────────────────────────────────

model StegBudget {
  id         String           @id @default(cuid())
  propertyId String
  companyId  String
  jahr       Int
  status     StegBudgetStatus @default(ENTWURF)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  property    Property             @relation("PropertyBudgets", fields: [propertyId], references: [id], onDelete: Cascade)
  company     Company              @relation("CompanyBudgets", fields: [companyId], references: [id], onDelete: Cascade)
  positionen  StegBudgetPosition[]
  agendaItems AgendaItem[]

  @@unique([propertyId, jahr])
}

model StegBudgetPosition {
  id           String          @id @default(cuid())
  budgetId     String
  kategorie    ExpenseCategory
  beschreibung String
  budgetBetrag Float
  istBetrag    Float           @default(0)
  notizen      String?

  budget StegBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
}

model StegJahresabrechnung {
  id            String                 @id @default(cuid())
  propertyId    String
  companyId     String
  jahr          Int
  status        JahresabrechnungStatus @default(ENTWURF)
  totalAusgaben Float                  @default(0)
  fondsBeitrag  Float                  @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  property        Property             @relation("PropertyJahresabrechnungen", fields: [propertyId], references: [id], onDelete: Cascade)
  company         Company              @relation("CompanyJahresabrechnungen", fields: [companyId], references: [id], onDelete: Cascade)
  ownerStatements StegOwnerStatement[]

  @@unique([propertyId, jahr])
}

model StegOwnerStatement {
  id                 String               @id @default(cuid())
  jahresabrechnungId String
  ownerId            String
  kostenanteil       Float
  fondsanteil        Float
  vorauszahlungen    Float
  saldo              Float
  pdfUrl             String?
  createdAt          DateTime             @default(now())

  jahresabrechnung StegJahresabrechnung @relation(fields: [jahresabrechnungId], references: [id], onDelete: Cascade)
  owner            PropertyOwner        @relation("OwnerStatements", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([jahresabrechnungId, ownerId])
}
