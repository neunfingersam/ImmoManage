// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  VERMIETER
  MIETER
  EIGENTUEMER
}

enum PropertyType {
  SINGLE
  MULTI
}

enum LeaseStatus {
  ACTIVE
  ENDED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum DocumentCategory {
  MIETVERTRAG
  HAUSORDNUNG
  NEBENKOSTENABRECHNUNG
  UEBERGABEPROTOKOLL
  SONSTIGES
}

enum DocumentScope {
  TENANT
  PROPERTY
  GLOBAL
}

enum MessageSource {
  MANUAL
  AI_ESCALATION
}

enum AgentRole {
  USER
  AGENT
}

enum MeterType {
  STROM
  GAS
  WASSER
  HEIZUNG
}

enum HandoverType {
  EINZUG
  AUSZUG
}

enum HandoverStatus {
  ENTWURF
  ABGESCHLOSSEN
}

enum CalendarEventType {
  VERTRAGSENDE
  ABLESUNG
  KUENDIGUNG
  WARTUNG
  SONSTIGES
}

enum UnitStatus {
  VERMIETET
  LEER
  RENOVIERUNG
}

enum DepositStatus {
  AUSSTEHEND
  HINTERLEGT
  FREIGEGEBEN
}

enum RentDemandStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  QR_RECHNUNG
}

enum TaskType {
  WARTUNG
  REPARATUR
  VERTRAGSVERLAENGERUNG
  BESICHTIGUNG
  SONSTIGES
}

enum TaskStatus {
  OFFEN
  IN_BEARBEITUNG
  ERLEDIGT
}

enum AccountDeletionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Company {
  id                   String          @id @default(cuid())
  name                 String
  slug                 String          @unique
  logoUrl              String?
  active               Boolean         @default(true)
  onboardingCompleted  Boolean         @default(false)
  smtpConfig           Json?
  createdAt            DateTime        @default(now())
  users                  User[]
  properties             Property[]
  tickets                Ticket[]
  documents              Document[]
  messages               Message[]
  leases                 Lease[]
  agentChats             AgentChat[]
  utilityBills           UtilityBill[]
  calendarEvents         CalendarEvent[]
  meterReadings          MeterReading[]
  handovers              Handover[]
  rentDemands            RentDemand[]
  tasks                  Task[]
  activityLogs           ActivityLog[]
  accountDeletionRequests AccountDeletionRequest[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role
  name         String
  phone        String?
  whatsapp     String?
  iban         String?
  active       Boolean  @default(true)
  companyId    String?
  createdAt    DateTime @default(now())
  company             Company?             @relation(fields: [companyId], references: [id])
  propertyAssignments PropertyAssignment[]
  propertyOwnerships  PropertyOwner[]
  leases              Lease[]              @relation("TenantLeases")
  tickets             Ticket[]             @relation("TenantTickets")
  ticketComments      TicketComment[]
  uploadedDocuments   Document[]           @relation("UploadedDocuments")
  tenantDocuments     Document[]           @relation("TenantDocuments")
  sentMessages        Message[]            @relation("SentMessages")
  receivedMessages    Message[]            @relation("ReceivedMessages")
  notifications       Notification[]
  calendarEvents      CalendarEvent[]
  agentChats          AgentChat[]          @relation("AgentChatTenant")
  passwordResetTokens PasswordResetToken[]
  meterReadings       MeterReading[]       @relation("TenantMeterReadings")
  activityLogs        ActivityLog[]
  deletionRequest     AccountDeletionRequest?
}

model PropertyAssignment {
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  @@id([userId, propertyId])
}

model PropertyOwner {
  id         String    @id @default(cuid())
  userId     String
  propertyId String
  unitId     String?
  ownerSince DateTime?
  createdAt  DateTime  @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit?    @relation(fields: [unitId], references: [id])
}

model Property {
  id          String       @id @default(cuid())
  companyId   String
  name        String
  address     String
  type        PropertyType
  unitCount   Int
  year        Int?
  description String?
  createdAt   DateTime     @default(now())
  company        Company              @relation(fields: [companyId], references: [id])
  units          Unit[]
  tickets        Ticket[]
  documents      Document[]
  assignments    PropertyAssignment[]
  owners         PropertyOwner[]
  utilityBills   UtilityBill[]
  calendarEvents CalendarEvent[]
  tasks          Task[]
}

model Unit {
  id         String     @id @default(cuid())
  propertyId String
  unitNumber String
  floor      Int?
  size       Float?
  rooms      Float?
  status     UnitStatus @default(LEER)
  photos     Json?
  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases         Lease[]
  tickets        Ticket[]
  owners         PropertyOwner[]
  calendarEvents CalendarEvent[]
}

model Lease {
  id                String        @id @default(cuid())
  unitId            String
  tenantId          String
  companyId         String
  status            LeaseStatus   @default(ACTIVE)
  startDate         DateTime
  endDate           DateTime?
  coldRent          Float
  extraCosts        Float
  depositPaid       Boolean       @default(false)
  depositAmount     Float?
  depositBank       String?
  depositStatus     DepositStatus @default(AUSSTEHEND)
  indexierung       Boolean       @default(false)
  referenzzinssatz  Float?
  contractPdf       String?
  handoverWizard    Json?
  createdAt         DateTime      @default(now())
  unit          Unit          @relation(fields: [unitId], references: [id])
  tenant        User          @relation("TenantLeases", fields: [tenantId], references: [id])
  company       Company       @relation(fields: [companyId], references: [id])
  utilityBills  UtilityBill[]
  meterReadings MeterReading[]
  handovers     Handover[]
  rentDemands   RentDemand[]
}

model Ticket {
  id          String       @id @default(cuid())
  companyId   String
  propertyId  String
  tenantId    String
  unitId      String?
  title       String
  description String
  status      TicketStatus @default(OPEN)
  priority    Priority     @default(MEDIUM)
  images      Json
  repairCost  Float?
  createdAt   DateTime     @default(now())
  company  Company         @relation(fields: [companyId], references: [id])
  property Property        @relation(fields: [propertyId], references: [id])
  tenant   User            @relation("TenantTickets", fields: [tenantId], references: [id])
  unit     Unit?           @relation(fields: [unitId], references: [id])
  comments TicketComment[]
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  text      String
  createdAt DateTime @default(now())
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])
}

model Document {
  id            String           @id @default(cuid())
  companyId     String
  name          String
  category      DocumentCategory
  fileUrl       String
  fileType      String
  scope         DocumentScope
  tenantId      String?
  propertyId    String?
  uploadedById  String
  extractedText String?
  indexed       Boolean          @default(false)
  createdAt     DateTime         @default(now())
  company    Company   @relation(fields: [companyId], references: [id])
  tenant     User?     @relation("TenantDocuments", fields: [tenantId], references: [id])
  property   Property? @relation(fields: [propertyId], references: [id])
  uploadedBy User      @relation("UploadedDocuments", fields: [uploadedById], references: [id])
}

model Message {
  id        String        @id @default(cuid())
  companyId String
  fromId    String
  toId      String
  text      String
  read      Boolean       @default(false)
  source    MessageSource @default(MANUAL)
  createdAt DateTime      @default(now())
  company Company @relation(fields: [companyId], references: [id])
  from    User    @relation("SentMessages", fields: [fromId], references: [id])
  to      User    @relation("ReceivedMessages", fields: [toId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  text      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
}

model UtilityBill {
  id              String    @id @default(cuid())
  leaseId         String
  companyId       String
  propertyId      String
  year            Int
  amount          Float
  costItems       Json?
  distributionKey String    @default("sqm")
  tenantShares    Json?
  pdfUrl          String?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  lease    Lease    @relation(fields: [leaseId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
}

model CalendarEvent {
  id            String            @id @default(cuid())
  companyId     String
  userId        String
  title         String
  date          DateTime
  type          CalendarEventType
  autoGenerated Boolean           @default(false)
  relatedId     String?
  propertyId    String?
  unitId        String?
  createdAt     DateTime          @default(now())
  company  Company   @relation(fields: [companyId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])
  unit     Unit?     @relation(fields: [unitId], references: [id])
}

model AgentChat {
  id        String   @id @default(cuid())
  companyId String
  tenantId  String
  createdAt DateTime @default(now())
  company  Company        @relation(fields: [companyId], references: [id])
  tenant   User           @relation("AgentChatTenant", fields: [tenantId], references: [id])
  messages AgentMessage[]
}

model AgentMessage {
  id           String    @id @default(cuid())
  chatId       String
  role         AgentRole
  content      String
  sources      Json
  wasEscalated Boolean   @default(false)
  createdAt    DateTime  @default(now())
  chat AgentChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MeterReading {
  id          String    @id @default(cuid())
  companyId   String
  leaseId     String
  tenantId    String
  type        MeterType
  value       Float
  unit        String    @default("kWh")
  readingDate DateTime
  imageUrl    String?
  note        String?
  createdAt   DateTime  @default(now())
  company Company @relation(fields: [companyId], references: [id])
  lease   Lease   @relation(fields: [leaseId], references: [id])
  tenant  User    @relation("TenantMeterReadings", fields: [tenantId], references: [id])
}

model Handover {
  id         String         @id @default(cuid())
  companyId  String
  leaseId    String
  type       HandoverType
  date       DateTime
  status     HandoverStatus @default(ENTWURF)
  notes      String?
  rooms      Json           // RoomEntry[] als JSON
  signedByTenant   Boolean  @default(false)
  signedByVermieter Boolean @default(false)
  createdAt  DateTime       @default(now())
  company Company @relation(fields: [companyId], references: [id])
  lease   Lease   @relation(fields: [leaseId], references: [id])
}

model RentDemand {
  id          String           @id @default(cuid())
  companyId   String
  leaseId     String
  month       Int              // 1–12
  year        Int
  amount      Float
  dueDate     DateTime
  status      RentDemandStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  company   Company         @relation(fields: [companyId], references: [id])
  lease     Lease           @relation(fields: [leaseId], references: [id])
  payments  Payment[]
  reminders PaymentReminder[]
}

model Payment {
  id            String        @id @default(cuid())
  rentDemandId  String
  amount        Float
  paymentDate   DateTime
  method        PaymentMethod @default(BANK_TRANSFER)
  note          String?
  createdAt     DateTime      @default(now())
  rentDemand RentDemand @relation(fields: [rentDemandId], references: [id])
}

model PaymentReminder {
  id           String   @id @default(cuid())
  rentDemandId String
  level        Int      // 1, 2, 3
  sentAt       DateTime @default(now())
  rentDemand RentDemand @relation(fields: [rentDemandId], references: [id])
}

model Task {
  id          String     @id @default(cuid())
  companyId   String
  title       String
  description String?
  type        TaskType   @default(SONSTIGES)
  status      TaskStatus @default(OFFEN)
  dueDate     DateTime?
  reminderDays Int?
  propertyId  String?
  leaseId     String?
  createdAt   DateTime   @default(now())
  company  Company   @relation(fields: [companyId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model AccountDeletionRequest {
  id         String                @id @default(cuid())
  userId     String                @unique
  companyId  String
  status     AccountDeletionStatus @default(PENDING)
  reason     String?
  createdAt  DateTime              @default(now())
  resolvedAt DateTime?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])
}
